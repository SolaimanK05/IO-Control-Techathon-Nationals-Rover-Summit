# ============================================================
# techathon-office-monitor — .env.example
# Copy this to .env in EACH service folder that needs it
# (simulator/.env, backend/.env, dashboard/.env.local, bot/.env)
# and fill in real values. Never commit the filled-in .env files.
# ============================================================

# --- Supabase (shared by simulator, backend, dashboard) ---
# From: Supabase Dashboard > Settings > API Keys
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Publishable key — safe for frontend (dashboard). New naming, replaces legacy "anon" key.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Secret key — backend/simulator ONLY. Never expose in dashboard/frontend code.
# New naming, replaces legacy "service_role" key.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx

# Direct Postgres connection (used for running migrations via CLI in Phase 1)
# From: Settings > Database > Connection string
SUPABASE_DB_URL=postgresql://postgres:<db-password>@<host>:5432/postgres

# --- Simulator ---
# 1 real second = N simulated hours. Tune per demo needs (Section 4.1 of plan).
SIM_HOURS_PER_REAL_SECOND=0.05

# Forces Scenario B (meeting burst) to cross the 2h-continuous threshold
# within the first simulated day — set true only for recording the demo video.
FORCE_DEMO_SCENARIOS=false

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Dashboard (Next.js) ---
# Public env vars (exposed to browser) — Next.js requires the NEXT_PUBLIC_ prefix
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# --- Discord Bot ---
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_ALERTS_CHANNEL_ID=123456789012345678

# Backend base URL the bot calls for /status, /room, /usage
BACKEND_BASE_URL=http://localhost:8000

# OpenRouter (free tier) — for humanizing bot responses
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx
OPENROUTER_MODEL=<to-be-selected-in-Phase-5>
OPENROUTER_RATE_LIMIT_PER_MIN=15
