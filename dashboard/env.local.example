# dashboard/.env.local — copy from this template, fill in real values,
# never commit .env.local itself.

# Supabase project URL (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# New-style publishable key (Project Settings -> API Keys -> Publishable key)
# NOT the legacy anon key, and NOT the secret key — publishable keys are
# safe to expose client-side, which is required here since this component
# is a Next.js Client Component subscribing directly from the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
